{
  "name": "nexus",
  "version": "1.0.0",
  "description": "NEXUS — Agent IA Personnel Desktop",
  "main": "src/main/main.js",
  "scripts": {
    "renderer:dev"    : "vite",
    "renderer:build"  : "vite build",
    "renderer:preview": "vite preview",
    "start"           : "node_modules/electron/dist/electron.exe .",
    "dev"             : "concurrently \"npm run renderer:dev\" \"cross-env NODE_ENV=development node_modules/electron/dist/electron.exe .\"",
    "rebuild-native"  : "electron-rebuild -f -w better-sqlite3",
    "build"           : "npm run renderer:build && electron-builder",
    "build:win"       : "npm run renderer:build && electron-builder --win"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "@google/generative-ai": "^0.24.1",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "@tailwindcss/vite": "^4.2.4",
    "axios": "^1.7.0",
    "dotenv": "^16.4.7",
    "better-sqlite3": "^11.0.0",
    "clsx": "^2.1.1",
    "electron-store": "^8.2.0",
    "framer-motion": "^12.38.0",
    "groq-sdk": "^1.1.2",
    "lucide-react": "^1.14.0",
    "msedge-tts": "^2.0.5",
    "node-cron": "^3.0.3",
    "ollama": "^0.5.0",
    "postprocessing": "^6.39.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.5.0",
    "three": "^0.184.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^28.3.3",
    "electron-builder": "^25.0.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.11"
  },
  "build": {
    "appId": "com.nexus.app",
    "productName": "NEXUS",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icons/nexus.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ]
  },
  "keywords": [
    "electron",
    "ai",
    "assistant",
    "productivity"
  ],
  "author": "NEXUS",
  "license": "MIT"
}
